  },
  "simulation": {
    "kind": "microcontroller",
    "effects": ["firmware", "electrical", "visual-state"],
    "implemented": true,
    "notes": [
      "The edge connector follows the micro:bit V2 pinout.",
      "The 5x5 LED matrix is exposed as simulated built-in pixel pins 100..124 for deterministic firmware examples; real hardware drives it by row/column multiplexing."
    ]
  },
  "properties": {
