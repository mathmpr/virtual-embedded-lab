      "type": "number",
      "default": 3.3,
      "unit": "V",
      "simulationUpdate": "rerun"
    },
    "displayBrightness": {
      "type": "number",
      "default": 100,
      "minimum": 0,
      "maximum": 100,
      "unit": "%",
      "simulationUpdate": "none"
    }
  },
