{
  "$schema": "../../../schemas/component.schema.json",
  "schemaVersion": "1.0.0",
  "identity": {
    "id": "environment.climate",
    "name": "Clima",
    "category": "environment",
    "subCategory": "weather"
  },
  "simulation": {
    "kind": "environment-source",
    "effects": ["environment"],
    "implemented": true
  },
  "properties": {
    "enabled": {
      "type": "boolean",
      "default": true,
      "simulationUpdate": "live"
    },
    "temperatureC": {
      "type": "number",
      "default": 25,
      "minimum": -40,
      "maximum": 85,
      "unit": "°C",
      "simulationUpdate": "live"
    },
    "pressureHpa": {
      "type": "number",
      "default": 1013.25,
      "minimum": 300,
      "maximum": 1100,
      "unit": "hPa",
      "simulationUpdate": "live"
    },
    "humidityPercent": {
      "type": "number",
      "default": 55,
      "minimum": 0,
      "maximum": 100,
      "unit": "%",
      "simulationUpdate": "live"
    }
  },
  "terminals": [
    { "id": "climate", "label": "ENV", "type": "environment-output" }
  ],
  "behavior": {
    "type": "environment-source",
    "channel": "climate",
    "activeProperty": "enabled",
    "temperatureProperty": "temperatureC",
    "pressureProperty": "pressureHpa",
    "humidityProperty": "humidityPercent"
  },
  "visual": {
    "type": "climate-environment",
    "title": "Clima",
    "className": "climate-environment",
    "body": "25 °C / 1013 hPa",
    "width": 210,
    "height": 124,
    "controls": [
      { "type": "readout", "className": "climate-readout", "label": "Clima", "property": "temperatureC", "unit": "°C", "activeProperty": "enabled", "inactiveText": "OFF" },
      { "type": "checkbox", "className": "wifi-checkbox-row", "label": "Clima ativo", "property": "enabled" },
      { "type": "range", "className": "compact-slider-row", "label": "°C", "property": "temperatureC" },
      { "type": "range", "className": "compact-slider-row", "label": "hPa", "property": "pressureHpa" },
      { "type": "range", "className": "compact-slider-row", "label": "%RH", "property": "humidityPercent" }
    ],
    "palette": {
      "group": "Inputs",
      "subgroup": "Weather",
      "icon": "climate-icon",
      "order": 38
    },
    "terminals": [
      { "id": "climate", "label": "ENV", "side": "right", "x": 210, "y": 62, "kind": "environment" }
    ]
  }
}
