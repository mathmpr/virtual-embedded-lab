{
  "$schema": "../../../schemas/component.schema.json",
  "schemaVersion": "1.0.0",
  "identity": {
    "id": "environment.distance-range",
    "name": "Controle de distância",
    "category": "environment"
  },
  "simulation": {
    "kind": "environment-source",
    "effects": ["environment"],
    "implemented": true
  },
  "properties": {
    "valueCm": {
      "type": "number",
      "default": 150,
      "minimum": 2,
      "maximum": 400,
      "unit": "cm",
      "simulationUpdate": "live"
    },
    "minCm": {
      "type": "number",
      "default": 2,
      "unit": "cm",
      "simulationUpdate": "none"
    },
    "maxCm": {
      "type": "number",
      "default": 400,
      "unit": "cm",
      "simulationUpdate": "none"
    }
  },
  "terminals": [
    { "id": "distance", "label": "Distância", "type": "environment-output" }
  ],
  "behavior": {
    "type": "environment-source",
    "channel": "distance",
