  },
  "visual": {
    "type": "distance",
    "title": "Distância",
    "className": "distance",
    "body": "150 cm",
    "width": 190,
    "height": 104,
    "controls": [
      { "type": "readout", "className": "distance-readout", "label": "Distância", "property": "valueCm", "unit": "cm" },
      { "type": "range", "property": "valueCm" }
    ],
    "palette": {
      "group": "Inputs",
      "icon": "distance-icon",
      "order": 30
    },
    "terminals": [
      { "id": "distance", "label": "ENV", "side": "left", "x": 0, "y": 58, "kind": "environment" }
    ]
  }
