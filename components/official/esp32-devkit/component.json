        "label": "PWR",
        "pin": null,
        "active": true,
        "color": "green",
        "description": "5V Power On LED; nao e controlado por GPIO."
      },
      {
        "id": "led_builtin",
        "label": "LD",
        "pin": 2,
        "terminalId": "io2",
        "activeHigh": true,
        "color": "blue",
        "description": "LED programavel associado ao GPIO2."
      }
    ],
    "notes": [
      "PWR e o LED de alimentacao 5V.",
      "LD e o LED programavel associado ao GPIO2 em placas ESP32 DevKit comuns.",
      "D0, D1, D2, D3, CMD e CLK sao reservados para SPI flash.",
      "GPIO16 e GPIO17 dependem do modulo ESP32 usado na placa."
    ]
