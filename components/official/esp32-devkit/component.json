      "tx": { "number": 1, "name": "GPIO1/TX0", "capabilities": ["digital", "uart-tx"] },
      "rx": { "number": 3, "name": "GPIO3/RX0", "capabilities": ["digital", "uart-rx"] },
      "io21": { "number": 21, "name": "GPIO21", "capabilities": ["digital", "pwm", "i2c-sda"] },
