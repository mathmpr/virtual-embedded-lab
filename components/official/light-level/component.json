{
  "$schema": "../../../schemas/component.schema.json",
  "schemaVersion": "1.0.0",
  "identity": {
    "id": "environment.light-level",
    "name": "Light Environment",
    "category": "environment",
    "subCategory": "light"
  },
  "simulation": {
    "kind": "environment-source",
    "effects": ["environment"],
    "implemented": true
  },
  "properties": {
    "enabled": {
      "type": "boolean",
      "default": true,
      "simulationUpdate": "live"
    },
    "intensityPercent": {
      "type": "number",
      "default": 50,
      "minimum": 0,
      "maximum": 100,
      "unit": "%",
      "simulationUpdate": "live"
    }
  },
  "terminals": [],
  "behavior": {
    "type": "environment-source",
    "channel": "light",
    "activeProperty": "enabled",
    "intensityProperty": "intensityPercent"
  },
  "visual": {
    "type": "light-level",
    "title": "Luz",
    "className": "light-level",
    "body": "50%",
    "width": 180,
    "height": 104,
    "controls": [
      { "type": "readout", "className": "light-readout", "label": "Luz", "property": "intensityPercent", "format": "percent", "activeProperty": "enabled", "inactiveText": "OFF" },
      { "type": "checkbox", "className": "wifi-checkbox-row", "label": "Luz ativa", "property": "enabled" },
      { "type": "range", "property": "intensityPercent" }
    ],
    "palette": {
      "group": "Inputs",
      "subgroup": "Light",
      "icon": "light-icon",
      "order": 37
    },
    "terminals": []
  }
}
