{
  "$schema": "../../../schemas/component.schema.json",
  "schemaVersion": "1.0.0",
  "identity": {
    "id": "environment.rain-toggle",
    "name": "Chuva",
    "category": "environment",
    "subCategory": "weather"
  },
  "simulation": {
    "kind": "environment-source",
    "effects": ["environment"],
    "implemented": true
  },
  "properties": {
    "active": {
      "type": "boolean",
      "default": false,
      "simulationUpdate": "live"
    },
    "intensityPercent": {
      "type": "number",
      "default": 100,
      "minimum": 0,
      "maximum": 100,
      "unit": "%",
      "simulationUpdate": "live"
    }
  },
  "terminals": [],
  "behavior": {
    "type": "environment-source",
    "channel": "rain",
    "activeProperty": "active",
    "intensityProperty": "intensityPercent"
  },
  "visual": {
    "type": "rain-toggle",
    "title": "Chuva",
    "className": "rain-toggle",
    "body": "OFF",
    "width": 180,
    "height": 104,
    "controls": [
      { "type": "readout", "className": "rain-readout", "label": "Chuva", "property": "active", "format": "onOff" },
      { "type": "checkbox", "className": "wifi-checkbox-row", "label": "Chuva ativa", "property": "active" },
      { "type": "range", "property": "intensityPercent" }
    ],
    "palette": {
      "group": "Inputs",
      "subgroup": "Weather",
      "icon": "rain-icon",
      "order": 36
    },
    "terminals": []
  }
}
