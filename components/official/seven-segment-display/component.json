{
  "$schema": "../../../schemas/component.schema.json",
  "schemaVersion": "1.0.0",
  "identity": {
    "id": "display.led.7segment",
    "name": "7-Segment LED Display",
    "category": "display",
    "subCategory": "led-display"
  },
  "simulation": {
    "kind": "active-electrical",
    "effects": ["electrical", "firmware", "visual-state"],
    "implemented": true
  },
  "properties": {
    "commonType": { "type": "string", "default": "cathode", "simulationUpdate": "rerun" },
    "forwardVoltageVolts": { "type": "number", "default": 2, "minimum": 1.6, "maximum": 3.4, "unit": "V", "simulationUpdate": "rerun" },
    "recommendedCurrentAmps": { "type": "number", "default": 0.01, "minimum": 0.001, "maximum": 0.02, "unit": "A", "simulationUpdate": "rerun" },
    "segmentA": { "type": "boolean", "default": false, "simulationUpdate": "live" },
    "segmentB": { "type": "boolean", "default": false, "simulationUpdate": "live" },
    "segmentC": { "type": "boolean", "default": false, "simulationUpdate": "live" },
    "segmentD": { "type": "boolean", "default": false, "simulationUpdate": "live" },
    "segmentE": { "type": "boolean", "default": false, "simulationUpdate": "live" },
    "segmentF": { "type": "boolean", "default": false, "simulationUpdate": "live" },
    "segmentG": { "type": "boolean", "default": false, "simulationUpdate": "live" },
    "segmentDp": { "type": "boolean", "default": false, "simulationUpdate": "live" }
  },
  "variants": {
    "commonType": [
      { "label": "Common cathode", "value": "cathode" },
      { "label": "Common anode", "value": "anode" }
    ]
  },
  "terminals": [
    { "id": "a", "label": "A", "type": "digital-input" },
    { "id": "b", "label": "B", "type": "digital-input" },
    { "id": "c", "label": "C", "type": "digital-input" },
    { "id": "d", "label": "D", "type": "digital-input" },
    { "id": "e", "label": "E", "type": "digital-input" },
    { "id": "f", "label": "F", "type": "digital-input" },
    { "id": "g", "label": "G", "type": "digital-input" },
    { "id": "dp", "label": "DP", "type": "digital-input" },
    { "id": "com1", "label": "COM", "type": "ground-capable" },
    { "id": "com2", "label": "COM", "type": "ground-capable" }
  ],
  "behavior": {
    "type": "seven-segment-display",
    "commonTypeProperty": "commonType",
    "segmentTerminals": {
      "a": "segmentA",
      "b": "segmentB",
      "c": "segmentC",
      "d": "segmentD",
      "e": "segmentE",
      "f": "segmentF",
      "g": "segmentG",
      "dp": "segmentDp"
    },
    "commonTerminals": ["com1", "com2"]
  },
  "contributions": {
    "styles": {
      "files": ["./ui/styles.css"]
    }
  },
  "electricalModel": {
    "type": "multi-led",
    "primitive": "seven-segment-led",
    "forwardVoltageProperty": "forwardVoltageVolts",
    "recommendedCurrentProperty": "recommendedCurrentAmps"
  },
  "visual": {
    "type": "seven-segment-display",
    "title": "7 Segment",
    "className": "seven-segment-display",
    "body": "",
    "width": 190,
    "height": 180,
    "controls": [
      {
        "type": "container",
        "className": "seven-segment-face",
        "children": [
          { "type": "element", "className": "segment segment-a", "dataAttribute": "data-segment=\"a\"" },
          { "type": "element", "className": "segment segment-b", "dataAttribute": "data-segment=\"b\"" },
          { "type": "element", "className": "segment segment-c", "dataAttribute": "data-segment=\"c\"" },
          { "type": "element", "className": "segment segment-d", "dataAttribute": "data-segment=\"d\"" },
          { "type": "element", "className": "segment segment-e", "dataAttribute": "data-segment=\"e\"" },
          { "type": "element", "className": "segment segment-f", "dataAttribute": "data-segment=\"f\"" },
          { "type": "element", "className": "segment segment-g", "dataAttribute": "data-segment=\"g\"" },
          { "type": "element", "className": "segment segment-dp", "dataAttribute": "data-segment=\"dp\"" }
        ]
      },
      { "type": "variant", "className": "component-select-row compact", "label": "COM", "property": "commonType" }
    ],
    "stateBindings": [
      { "type": "class", "selector": "[data-segment=\"a\"]", "className": "is-on", "source": { "kind": "componentProperty", "property": "segmentA" }, "when": true },
      { "type": "class", "selector": "[data-segment=\"b\"]", "className": "is-on", "source": { "kind": "componentProperty", "property": "segmentB" }, "when": true },
      { "type": "class", "selector": "[data-segment=\"c\"]", "className": "is-on", "source": { "kind": "componentProperty", "property": "segmentC" }, "when": true },
      { "type": "class", "selector": "[data-segment=\"d\"]", "className": "is-on", "source": { "kind": "componentProperty", "property": "segmentD" }, "when": true },
      { "type": "class", "selector": "[data-segment=\"e\"]", "className": "is-on", "source": { "kind": "componentProperty", "property": "segmentE" }, "when": true },
      { "type": "class", "selector": "[data-segment=\"f\"]", "className": "is-on", "source": { "kind": "componentProperty", "property": "segmentF" }, "when": true },
      { "type": "class", "selector": "[data-segment=\"g\"]", "className": "is-on", "source": { "kind": "componentProperty", "property": "segmentG" }, "when": true },
      { "type": "class", "selector": "[data-segment=\"dp\"]", "className": "is-on", "source": { "kind": "componentProperty", "property": "segmentDp" }, "when": true }
    ],
    "palette": {
      "group": "Displays",
      "subgroup": "LED Displays",
      "icon": "seven-segment-icon",
      "order": 72
    },
    "terminals": [
      { "id": "f", "label": "F", "side": "left", "x": 0, "y": 34, "kind": "signal" },
      { "id": "g", "label": "G", "side": "left", "x": 0, "y": 72, "kind": "signal" },
      { "id": "e", "label": "E", "side": "left", "x": 0, "y": 110, "kind": "signal" },
      { "id": "d", "label": "D", "side": "bottom", "x": 58, "y": 180, "kind": "signal" },
      { "id": "com1", "label": "COM", "side": "bottom", "x": 94, "y": 180, "kind": "ground" },
      { "id": "dp", "label": "DP", "side": "bottom", "x": 134, "y": 180, "kind": "signal" },
      { "id": "a", "label": "A", "side": "right", "x": 190, "y": 34, "kind": "signal" },
      { "id": "b", "label": "B", "side": "right", "x": 190, "y": 72, "kind": "signal" },
      { "id": "c", "label": "C", "side": "right", "x": 190, "y": 110, "kind": "signal" },
      { "id": "com2", "label": "COM", "side": "top", "x": 94, "y": 0, "kind": "ground" }
    ]
  }
}
