{
  "$schema": "../../../schemas/component.schema.json",
  "schemaVersion": "1.0.0",
  "identity": {
    "id": "environment.wifi-signal",
    "name": "Wi-Fi Signal",
    "category": "environment",
    "subCategory": "wireless"
  },
  "simulation": {
    "kind": "environment-source",
    "effects": ["environment", "firmware"],
    "implemented": true
  },
  "properties": {
    "ssid": {
      "type": "string",
      "default": "VirtualLab",
      "simulationUpdate": "rerun"
    },
    "connected": {
      "type": "boolean",
      "default": true,
      "simulationUpdate": "rerun"
    },
    "strengthPercent": {
      "type": "number",
      "default": 80,
      "minimum": 0,
      "maximum": 100,
      "unit": "%",
      "simulationUpdate": "rerun"
    }
  },
  "terminals": [],
  "behavior": {
    "type": "wireless-environment",
    "capability": "wifi"
  },
  "visual": {
    "type": "wifi-signal",
    "title": "Wi-Fi Signal",
    "className": "wifi-signal",
    "body": "80%",
    "width": 210,
    "height": 122,
    "controls": [
      { "type": "readout", "className": "wifi-readout", "label": "Wi-Fi", "property": "strengthPercent", "format": "percent" },
      { "type": "checkbox", "className": "wifi-checkbox-row", "label": "Internet ativa", "property": "connected" },
      { "type": "range", "property": "strengthPercent" }
    ],
    "palette": {
      "group": "Inputs",
      "subgroup": "Wireless",
      "icon": "wifi-icon",
      "order": 35
    },
    "terminals": []
  }
}
