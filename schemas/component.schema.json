{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://virtual-embedded-lab.local/schemas/component.schema.json",
  "title": "Virtual Embedded Lab Component",
  "type": "object",
  "required": ["schemaVersion", "identity", "simulation", "terminals"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "type": "string" },
    "identity": {
      "type": "object",
      "required": ["id", "name", "category"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "subCategory": { "type": "string" }
      },
      "additionalProperties": false
    },
    "simulation": {
      "type": "object",
      "required": ["kind", "effects", "implemented"],
      "properties": {
        "kind": {
          "enum": [
            "visual-only",
            "passive-electrical",
            "active-electrical",
            "behavioral-sensor",
            "environment-source",
            "microcontroller"
          ]
        },
        "effects": {
          "type": "array",
          "items": {
            "enum": ["electrical", "firmware", "environment", "visual-state"]
          },
          "uniqueItems": true
        },
        "implemented": { "type": "boolean" },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "properties": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type", "default"],
        "properties": {
          "type": { "enum": ["number", "string", "boolean"] },
          "default": {},
          "minimum": { "type": "number" },
          "maximum": { "type": "number" },
          "unit": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "variants": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["label", "value"],
          "properties": {
            "label": { "type": "string", "minLength": 1 },
            "value": { "type": "number" }
          },
          "additionalProperties": false
        }
      }
    },
    "terminals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "type"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "power": { "type": "object" },
    "environmentInputs": { "type": "array" },
    "electricalModel": { "type": "object" },
    "behavior": { "type": "object" },
    "visual": { "type": "object" },
    "visualBehavior": { "type": "object" }
  },
  "additionalProperties": false
}
